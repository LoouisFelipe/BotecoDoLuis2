{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Product categories (e.g., Drinks, Food, Snacks)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Product": {
      "title": "Product",
      "description": "Items available for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "categoryId": { "type": "string" },
        "subcategory": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "unit": { "type": "string" },
        "active": { "type": "boolean" },
        "isOpenValue": { "type": "boolean" },
        "isDoseControl": { "type": "boolean" },
        "volumePerUnit": { "type": "number" },
        "currentBottleVolume": { "type": "number" },
        "linkedProductId": { "type": "string" },
        "doseSize": { "type": "number" }
      },
      "required": ["name", "categoryId", "price", "cost", "stock"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer records",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "balance": { "type": "number", "description": "Current debt or credit balance. Negative means debt." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Product suppliers",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "phone": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "GameModality": {
      "title": "GameModality",
      "description": "Types of games (Banca de Jogos)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "price"]
    },
    "GameSession": {
      "title": "GameSession",
      "description": "Recorded result of a game session",
      "type": "object",
      "properties": {
        "modalityId": { "type": "string" },
        "modalityName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userName": { "type": "string" }
      },
      "required": ["modalityId", "amount", "date", "userId"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders/tables",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerId": { "type": "string", "description": "Reference to Customer entity if it is a loyal customer" },
        "status": { "type": "string", "enum": ["open", "closed", "cancelled"] },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "payments": { 
          "type": "array", 
          "description": "List of payments made for this order (supports splitting)",
          "items": {
            "type": "object",
            "properties": {
              "method": { "type": "string", "enum": ["dinheiro", "pix", "credito", "debito", "vr", "fiado"] },
              "amount": { "type": "number" },
              "date": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "closedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["customerName", "status", "totalAmount"]
    },
    "BISummary": {
      "title": "BISummary",
      "description": "Monthly business intelligence summaries",
      "type": "object",
      "properties": {
        "month": { "type": "string" },
        "salesCount": { "type": "number" },
        "totalExpenses": { "type": "number" },
        "totalRevenue": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["month", "salesCount", "totalExpenses", "totalRevenue"]
    },
    "PaymentFee": {
      "title": "PaymentFee",
      "description": "Fees for different payment methods",
      "type": "object",
      "properties": {
        "method": { "type": "string" },
        "percentage": { "type": "number" },
        "fixed": { "type": "number" }
      },
      "required": ["method", "percentage"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Inventory purchases from suppliers",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["supplierId", "totalAmount", "date"]
    },
    "RecurringExpense": {
      "title": "RecurringExpense",
      "description": "Fixed monthly expenses",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "dayOfMonth": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["description", "amount", "dayOfMonth"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Income and expense records",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "orderId": { "type": "string" }
      },
      "required": ["type", "amount", "date"]
    },
    "User": {
      "title": "User",
      "description": "Application users and roles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/categories/{categoryId}": { "schema": "Category", "description": "Product categories" },
    "/products/{productId}": { "schema": "Product", "description": "Available products" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer list" },
    "/suppliers/{supplierId}": { "schema": "Supplier", "description": "Supplier list" },
    "/game_modalities/{gameId}": { "schema": "GameModality", "description": "Game types" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/open_orders/{orderId}": { "schema": "Order", "description": "Specifically open orders" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Financial records" },
    "/expenses/{expenseId}": { "schema": "Transaction", "description": "Specific expense records" },
    "/recurring_expenses/{expenseId}": { "schema": "RecurringExpense", "description": "Fixed monthly expenses" },
    "/purchases/{purchaseId}": { "schema": "Purchase", "description": "Inventory purchases" },
    "/payment_fees/{feeId}": { "schema": "PaymentFee", "description": "Payment method fees" },
    "/bi_summaries/{summaryId}": { "schema": "BISummary", "description": "Monthly BI summaries" },
    "/users/{userId}": { "schema": "User", "description": "User profiles and roles" }
  }
}
