rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Master Bypass for Owner
    match /{document=**} {
      allow read, write: if request.auth != null && 
        (request.auth.token.email == "louisfelipecabral@gmail.com" || 
         request.auth.uid == "e5SB016rBhWuYEKifTIYSCfE5Bq2");
    }
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null && 
        (request.auth.token.email_verified == true || 
         request.auth.token.email == "louisfelipecabral@gmail.com" ||
         request.auth.uid == "e5SB016rBhWuYEKifTIYSCfE5Bq2");
    }

    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == "louisfelipecabral@gmail.com" ||
         request.auth.uid == "e5SB016rBhWuYEKifTIYSCfE5Bq2" ||
         (isAuthenticated() && 
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isStaff() {
      return request.auth != null && 
        (request.auth.token.email == "louisfelipecabral@gmail.com" ||
         request.auth.uid == "e5SB016rBhWuYEKifTIYSCfE5Bq2" ||
         isAdmin() ||
         (isAuthenticated() && 
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff'));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /categories/{categoryId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /suppliers/{supplierId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /game_modalities/{gameId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /game_sessions/{sessionId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /closed_orders/{orderId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /open_orders/{orderId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /recurring_expenses/{expenseId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /bi_summaries/{summaryId} {
      allow read: if isStaff();
      allow write: if isAdmin(); 
    }

    match /payment_fees/{feeId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
