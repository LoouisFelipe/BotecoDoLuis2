rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "louisfelipecabral@gmail.com" && request.auth.token.email_verified == true));
    }

    function isStaff() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff']);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /categories/{categoryId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /suppliers/{supplierId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /game_modalities/{gameId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /open_orders/{orderId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isAdmin();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if isAdmin();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /recurring_expenses/{expenseId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /bi_summaries/{summaryId} {
      allow read: if isAdmin();
      allow write: if false; // Only system/cloud functions should write here usually
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
