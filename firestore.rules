rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function authenticated() {
      return request.auth != null;
    }

    function isOwner() {
      return authenticated() && 
        (request.auth.token.email == "louisfelipecabral@gmail.com" || 
         request.auth.uid == "e5SB016rBhWuYEKifTIYSCfE5Bq2");
    }

    function isAdmin() {
      return isOwner() || (
        authenticated() && 
        request.auth.token.email_verified == true && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isStaff() {
      return isAdmin() || (
        authenticated() && 
        request.auth.token.email_verified == true && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff'
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if authenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if authenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /categories/{categoryId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /suppliers/{supplierId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /game_modalities/{gameId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /game_sessions/{sessionId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if authenticated();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /closed_orders/{orderId} {
      allow read: if authenticated();
      allow write: if isAdmin();
    }

    match /open_orders/{orderId} {
      allow read: if authenticated();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /recurring_expenses/{expenseId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /bi_summaries/{summaryId} {
      allow read: if isStaff();
      allow write: if isAdmin(); 
    }

    match /payment_fees/{feeId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Explicitly allow owner to do everything
    match /{document=**} {
      allow read, write: if isOwner();
    }
  }
}
