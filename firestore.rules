rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Catch-all for Safety
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Shared Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner() {
      return isSignedIn() && (
        request.auth.uid == "e5SB016rBhWuYEKifTIYSCfE5Bq2" || 
        request.auth.token.email == "louisfelipecabral@gmail.com"
      );
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isAdmin() {
      return isOwner() || (
        isVerified() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData(request.auth.uid).role == 'admin'
      );
    }

    function isStaff() {
      return isAdmin() || (
        isVerified() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData(request.auth.uid).role == 'staff'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidGameSession(data) {
      return data.modalityId is string && isValidId(data.modalityId) &&
             data.amount is number &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.date is timestamp;
    }

    function isValidTransaction(data) {
      return data.amount is number && data.amount >= 0 &&
             data.type in ['income', 'expense'] &&
             data.category is string &&
             data.date is timestamp;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isVerified() && (request.auth.uid == userId || isAdmin());
      allow create: if isVerified() && request.auth.uid == userId;
      allow update: if isVerified() && (
        isAdmin() || (
          request.auth.uid == userId && 
          !incoming().diff(existing()).affectedKeys().hasAny(['role'])
        )
      );
    }

    match /game_sessions/{sessionId} {
      // Allow all verified users to list/get game sessions for transparency in the bar
      allow read: if isVerified();
      
      allow create: if isStaff() && isValidGameSession(incoming()) && (
        incoming().keys().hasAll(['modalityId', 'modalityName', 'amount', 'date', 'userId', 'userName']) &&
        incoming().keys().size() >= 6
      );
      allow update, delete: if isAdmin() && isValidId(sessionId);
    }

    match /game_modalities/{gameId} {
      allow read: if isStaff();
      allow write: if isAdmin() && isValidId(gameId);
    }

    match /products/{productId} {
      allow read: if isStaff();
      allow write: if isAdmin() && isValidId(productId);
    }

    match /categories/{categoryId} {
      allow read: if isStaff();
      allow write: if isAdmin() && isValidId(categoryId);
    }

    match /customers/{customerId} {
      allow read: if isStaff();
      allow write: if isStaff() && isValidId(customerId);
    }

    match /suppliers/{supplierId} {
      allow read: if isStaff();
      allow write: if isAdmin() && isValidId(supplierId);
    }

    match /transactions/{transactionId} {
      allow list: if isStaff();
      allow get: if isStaff() && isValidId(transactionId);
      allow create: if isStaff() && isValidTransaction(incoming());
      allow update, delete: if isAdmin() && isValidId(transactionId);
    }

    match /expenses/{expenseId} {
      allow list: if isStaff();
      allow get: if isStaff() && isValidId(expenseId);
      allow create: if isStaff() && isValidTransaction(incoming());
      allow update, delete: if isAdmin() && isValidId(expenseId);
    }

    match /open_orders/{orderId} {
      allow list: if isStaff();
      allow get: if isStaff() && isValidId(orderId);
      allow create, update: if isStaff() && isValidId(orderId);
      allow delete: if isAdmin() && isValidId(orderId);
    }

    match /closed_orders/{orderId} {
      allow read: if isStaff();
      allow write: if isAdmin() && isValidId(orderId);
    }

    match /recurring_expenses/{expenseId} {
      allow read, write: if isAdmin() && isValidId(expenseId);
    }

    match /purchases/{purchaseId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidId(purchaseId);
      allow update, delete: if isAdmin() && isValidId(purchaseId);
    }

    match /payment_fees/{feeId} {
      allow read: if isStaff();
      allow write: if isAdmin() && isValidId(feeId);
    }

    match /bi_summaries/{summaryId} {
      allow read: if isStaff();
      allow write: if isAdmin() && isValidId(summaryId);
    }
  }
}
