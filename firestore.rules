rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "louisfelipecabral@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isStaff() {
      return isAuthenticated() && 
        (request.auth.token.email.matches(".*@gmail.com") && (
          request.auth.token.email == "louisfelipecabral@gmail.com" ||
          isAdmin() || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff')
        ));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /categories/{categoryId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /suppliers/{supplierId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /game_modalities/{gameId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /open_orders/{orderId} {
      allow read: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /recurring_expenses/{expenseId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /bi_summaries/{summaryId} {
      allow read: if isStaff();
      allow write: if isAdmin(); 
    }

    match /payment_fees/{feeId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
